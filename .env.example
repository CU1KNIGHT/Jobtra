# ─── Job Application Tracker — environment ──────────────────────────────────
# Copy this file to ".env" and adjust as needed:  cp .env.example .env
# Used by Docker Compose and (optionally) by the local-run scripts.

# Address you type in your browser. Also used for the "save job" bookmarklet
# link, so set it to your machine's hostname or LAN IP if you reach the app
# from another device. Leave as localhost for single-machine use.
HOST=localhost

# Port the app is served on (host and container).
PORT=8000

# LLM provider API keys — fill in only the provider(s) you actually use.
# (Ollama needs no key.)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
